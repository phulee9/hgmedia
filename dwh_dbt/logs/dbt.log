[0m02:58:53.527160 [debug] [Thread-1 (]: On model.dwh_hgmedia.fact_revenue_yt: /* {"app": "dbt", "dbt_version": "1.12.0b3", "profile_name": "dwh_hgmedia", "target_name": "dev", "node_id": "model.dwh_hgmedia.fact_revenue_yt"} */

      
  
    

  create  table "hgmediadb"."silver"."fact_revenue_yt"
  
  
    as
  
  (
    with dedup_metric as (
    select distinct on ("YoutubeVideoId", "Date")
        "YoutubeVideoId",
        "EstimatedRevenue",
        "Date"
    from "hgmediadb"."staging"."channel_video_metric"
    where nullif(trim("YoutubeVideoId"),'') is not null
    order by "YoutubeVideoId", "Date"
),

usd as (
    select distinct on (record_date)
        record_date,
        exchange_rate
    from "hgmediadb"."silver"."dim_usd"
    order by record_date
)

select
    md5(cast(coalesce(cast("YoutubeVideoId" as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast("Date" as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_revenue_yt_sk
    , nullif(trim("YoutubeVideoId"),'') as video_id
    , "EstimatedRevenue"::numeric as revenue_amount
    , cast(nullif(trim("Date"),'') as timestamp) as revenue_date
    , u.exchange_rate
from dedup_metric m
left join usd u
    on cast(nullif(trim(m."Date"),'') as date) = u.record_date
  );
  
  
