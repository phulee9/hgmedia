[0m03:18:08.068309 [debug] [Thread-1 (]: On model.dwh_hgmedia.fact_distribution: /* {"app": "dbt", "dbt_version": "1.12.0b3", "profile_name": "dwh_hgmedia", "target_name": "dev", "node_id": "model.dwh_hgmedia.fact_distribution"} */

      
  
    

  create  table "hgmediadb"."silver"."fact_distribution"
  
  
    as
  
  (
    -- silver.fact_distribution
select
    md5(cast(coalesce(cast(d."Id" as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_distribution_sk
    , d."Id" as distribution_id
    , d."ResourceFileInfoId" as hg_stock_id
    , cast(d."CreatedDate" as timestamp) as distribution_date
    , coalesce(cmp.company_name, 'Dùng chung') as recipient_company
    , dep.dept_names as department
    , grp.team_names as team
    , usr.emp_names as employee
    , d."CreatedByUserId" as distributed_employee_id
from "hgmediadb"."staging"."distribution_media_history" d

-- Department: unnest DepartmentData (comma GUIDs) -> join Department.Name
left join lateral (
    select string_agg(dd.name, ', ') as dept_names
    from unnest(string_to_array(nullif(d."DepartmentData",''), ',')) g(id)
    join "hgmediadb"."staging"."department" dd on trim(g.id) = dd."Id"::text
) dep on true

-- Team: unnest GroupData -> groups.Name
left join lateral (
    select string_agg(gg."Name", ', ') as team_names
    from unnest(string_to_array(nullif(d."GroupData",''), ',')) g(id)
    join "hgmediadb"."staging"."groups" gg on trim(g.id) = gg."Id"::text
) grp on true

-- Employee: unnest UserData -> users.DisplayName
left join lateral (
    select string_agg(uu."DisplayName", ', ') as emp_names
    from unnest(string_to_array(nullif(d."UserData",''), ',')) g(id)
    join "hgmediadb"."staging"."users" uu on trim(g.id) = uu."Id"::text
) usr on true

-- Recipient_Company: ProjectData/ChannelData -> Channel -> Company (đơn giản hoá, để null nếu không map được)
left join "hgmediadb"."staging"."company" cmp on false  -- TODO: chuỗi join Channel->Company chưa rõ khóa
  );
  
  
