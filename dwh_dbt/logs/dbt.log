  create  table "hgmediadb"."silver_silver"."fact_editing"
  
  
    as
  
  (
    with resource_editings as (

    select
        "Id"            as resource_editing_id,
        "EditingId"     as editing_id,
        "ResourcesId"   as resource_id,
        "StartTime"     as start_time,
        "EndTime"       as end_time,
        "IsDeleted"     as is_deleted
    from "hgmediadb"."staging"."resource_editings"
    where "IsDeleted" = false

),

editings as (

    select
        "Id"             as editing_id,
        "EditingFileId"  as editing_code
    from "hgmediadb"."staging"."editings"
    where "IsDeleted" = false

),

resources as (

    select
        "Id"              as resource_id,
        "ResourceFileId"  as hg_stock_id
    from "hgmediadb"."staging"."resource"

),

final as (

    select
        md5(cast(coalesce(cast(re.Id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as editing_sk,
        e.editing_id                                       as "Editing_ID",
        e.editing_code                                      as "Editing_Code",
        r.hg_stock_id                                        as "HG_Stock_ID",
        row_number() over (
            partition by re.editing_id
            order by re.start_time
        )                                                    as "Position",
        (re.end_time - re.start_time)                         as "Duration"
    from resource_editings re
    left join editings  e on re.editing_id = e.editing_id
    left join resources r on re.resource_id = r.resource_id

)

select * from final
  );
  
  
