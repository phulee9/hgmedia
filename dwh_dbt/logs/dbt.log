  create  table "hgmediadb"."silver"."fact_revenue_by_resources"
  
  
    as
  
  (
    with vid_metric as (
    select "YoutubeVideoId" as video_id, "Date" as recorded_date,
           cast(nullif("EstimatedRevenue",'') as numeric) as revenue,
           cast(nullif("Views",'') as numeric) as views
    from "hgmediadb"."staging"."channel_video_metric"
),
-- video -> editing_code -> các TN + vị trí
vid_res as (
    select b.video_id, f.hg_stock_id, f.position,
           count(*) over (partition by b.video_id, b.editing_code) as n_res,
           row_number() over (partition by b.video_id order by f.position) as rn
    from "hgmediadb"."silver"."bridge_bt_vid" b
    join "hgmediadb"."silver"."fact_editing" f on b.editing_code = f.editing_code
),
-- trọng số phân bổ theo số TN và vị trí (tổng = 10)
weighted as (
    select vr.*,
        case
          when n_res >= 5 then (array[5,2,1,1,1])[least(rn,5)]
          when n_res = 4 then (array[6,2,1,1])[rn]
          when n_res = 3 then (array[6,3,1])[rn]
          when n_res = 2 then (array[7,3])[rn]
          else 10
        end as w
    from vid_res vr
)
select
    md5(cast(coalesce(cast(w.video_id as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(w.hg_stock_id as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(m.recorded_date as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as revenue_id
    , w.video_id
    , w.hg_stock_id as resource_id
    , m.revenue * w.w / 10.0 as revenue_amount
    , m.recorded_date
    , m.views * w.w / 10.0 as view
from weighted w
join vid_metric m on w.video_id = m.video_id
  );
  
  
