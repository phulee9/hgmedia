  create  table "hgmediadb"."silver_silver"."fact_purchase_cost"
  
  
    as
  
  (
    -- silver.fact_purchase_cost
with cost as (
    select *, "_year" as year_no
    from "hgmediadb"."staging"."purchase_cost"
),
-- map "Tên đối tác" -> "Tên kho trên HG Stock"
kho as (
    select distinct
        trim("Tên đối tác") as partner_name,
        trim("Tên kho trên HG Stock") as repo_name
    from "hgmediadb"."staging"."partners"
    where nullif(trim("Tên kho trên HG Stock"), '') is not null
),
unpivoted as (
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 1 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 1" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 2 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 2" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 3 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 3" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 4 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 4" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 5 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 5" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 6 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 6" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 7 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 7" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 8 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 8" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 9 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 9" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 10 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 10" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 11 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 11" as add_cost_raw
    from cost c
    union all
    
    select
        trim(c."Tên đối tác") as partner_name
      , c.year_no
      , 12 as month_no
      , c."Total năm" as total_year_raw
      , c."Số bài hát" as song_count_raw
      , c."CP tháng 12" as add_cost_raw
    from cost c
    
    
),
num as (
    select
        u.*,
        cast(nullif(regexp_replace(u.song_count_raw,   '[^0-9]', '', 'g'), '') as numeric) as song_count,
        cast(nullif(regexp_replace(u.total_year_raw,   '[^0-9]', '', 'g'), '') as numeric) as total_year,
        cast(nullif(regexp_replace(u.add_cost_raw,     '[^0-9]', '', 'g'), '') as numeric) as add_cost
    from unpivoted u
)
select
    md5(cast(coalesce(cast(pr.hg_stock_id as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(n.year_no as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(n.month_no as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as cost_id
    , pr.hg_stock_id as resource_id
    , n.total_year / nullif(n.song_count, 0) as total_cost
    , n.add_cost  / nullif(n.song_count, 0) as additional_cost
    , (date_trunc('month', make_date(n.year_no::int, n.month_no, 1)) + interval '1 month - 1 day')::date as incurred_datetime
from num n
join kho k on n.partner_name = k.partner_name
join "hgmediadb"."silver_silver"."dim_purchased_resource" pr on trim(pr.repository) = k.repo_name
where n.add_cost is not null
  );
  
  
