  create  table "hgmediadb"."silver"."fact_revenue_distro"
  
  
    as
  
  (
    select
    md5(cast(coalesce(cast(retailer as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast("iSRC" as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(to_char(cast("reportingPeriod" as date),YYYY-MM) as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_revenue_distro_sk
    , sum(earnings::numeric) as revenue_amount
    , to_char(cast("reportingPeriod" as date),'YYYY-MM') as revenue_month
    , nullif(trim(retailer),'') as platform
    , nullif(trim("iSRC"),'') as isrc
    , nullif(trim(artist),'') as artist
from "hgmediadb"."staging"."sale"
where nullif(trim("iSRC"),'') is not null
group by retailer, "iSRC", artist, to_char(cast("reportingPeriod" as date),'YYYY-MM')
  );
  
  
