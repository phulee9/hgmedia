  create  table "hgmediadb"."silver"."fact_view_yt"
  
  
    as
  
  (
    -- silver.fact_view_yt  (target theo Data Dictionary)
select
    md5(cast(coalesce(cast("YoutubeVideoId" as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast("Date" as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_view_yt_sk
    , nullif(trim("YoutubeVideoId"),'') as video_id
    , cast(nullif(trim(cast("Views" as text)),'') as numeric) as view_count
    , cast(nullif(trim("Date"),'') as timestamp) as recorded_date
    , cast(nullif(trim(cast("EstimatedRevenue" as text)),'') as numeric)
        / nullif(cast(nullif(trim(cast("Views" as text)),'') as numeric),0) as rpm
from "hgmediadb"."staging"."channel_video_metric"
where nullif(trim("YoutubeVideoId"),'') is not null
  );
  
  
