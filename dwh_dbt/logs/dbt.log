    as
  
  (
    -- silver.dim_order_employee
select distinct on (udp."UserId")
    md5(cast(coalesce(cast(udp."UserId" as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as dim_order_employee_sk
    , nullif(trim(cast(udp."UserId" as text)),'') as order_employee_id
    , nullif(trim(cast(udp."DepartmentId" as text)),'') as department_id
    , nullif(trim(cast(u."FullName" as text)),'') as employee_name
    , null as team_name
    , nullif(trim(cast(p."Name" as text)),'') as position
from "hgmediadb"."staging"."userdepartmentposition" udp
left join "hgmediadb"."staging"."user" u
    on cast(udp."UserId" as text) = cast(u."Id" as text)
left join "hgmediadb"."staging"."position" p
    on cast(udp."PositionId" as text) = cast(p."Id" as text)
where udp."UserId" is not null
order by udp."UserId"
  );
  
