  create  table "hgmediadb"."silver"."fact_revenue_yt__dbt_tmp"
  
  
    as
  
  (
    

with dedup_metric as (
    select distinct on ("YoutubeVideoId", "Date")
        "YoutubeVideoId"
        , "EstimatedRevenue"::numeric as revenue_amount
        , "Date"::date as revenue_date
    from "hgmediadb"."staging"."channel_video_metric"
    where "YoutubeVideoId" is not null
        and trim("YoutubeVideoId") <> ''
        and "Date" is not null
    order by "YoutubeVideoId", "Date"
),

usd as (
    select distinct on (record_date)
        record_date
        , exchange_rate
    from "hgmediadb"."silver"."dim_usd"
    order by record_date
)

select
    md5(cast(coalesce(cast("YoutubeVideoId" as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(revenue_date::text as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_revenue_yt_sk
    , "YoutubeVideoId" as video_id
    , revenue_amount
    , revenue_date::timestamp as revenue_date
    , u.exchange_rate
from dedup_metric m
left join usd u on m.revenue_date = u.record_date
  );
  
