    -- silver.fact_youtube_operation  (target theo Data Dictionary)


select distinct on (hg_code)
    md5(cast(coalesce(cast(hg_code as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_youtube_operation_sk
