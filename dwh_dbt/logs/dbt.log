  create  table "hgmediadb"."silver"."fact_view_stream_distro"
  
  
    as
  
  (
    select
    md5(cast(coalesce(cast(retailer as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast("iSRC" as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast("reportingPeriod" as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_view_stream_distro_sk
    , replace(stream,',','')::numeric as stream_count
    , cast(nullif(trim("reportingPeriod"),'') as date) as recorded_date
    , nullif(trim(retailer),'') as platform
    , nullif(trim("iSRC"),'') as isrc
    , nullif(trim(artist),'') as artist
from "hgmediadb"."staging"."sale"
where nullif(trim("iSRC"),'') is not null
  );
  
  
