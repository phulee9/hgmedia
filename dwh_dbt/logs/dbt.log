        on cast(ucv."VersionNeedsCommentId" as text) = cast(vnc."Id" as text)
    group by vnc."RecordingSoundVersionId"
)
select
    md5(cast(coalesce(cast(r."Id" as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as music_evaluation_id
